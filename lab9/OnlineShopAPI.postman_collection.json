{
	"info": {
		"_postman_id": "8a8a8a8a-8a8a-8a8a-8a8a-8a8a8a8a8a8a",
		"name": "Online Shop API (Full Workflow)",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Categories",
			"item": [
				{
					"name": "Get All Categories",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.length > 0) {",
									"    // Get the first ID for retrieval/updates",
									"    pm.collectionVariables.set(\"active_category_id\", jsonData[0].id);",
									"    ",
									"    // Get the last ID for deletions (per user request)",
									"    pm.collectionVariables.set(\"last_category_id\", jsonData[jsonData.length - 1].id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": "http://localhost:8000/api/categories/"
					}
				},
				{
					"name": "Get Category by ID",
					"request": {
						"method": "GET",
						"header": [],
						"url": "http://localhost:8000/api/categories/{{active_category_id}}/"
					}
				},
				{
					"name": "Get Products by Category",
					"request": {
						"method": "GET",
						"header": [],
						"url": "http://localhost:8000/api/categories/{{active_category_id}}/products/"
					}
				},
				{
					"name": "Create Category",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\"name\": \"Dynamic Category\"}",
							"options": {"raw": {"language": "json"}}
						},
						"url": "http://localhost:8000/api/categories/"
					}
				}
			]
		},
		{
			"name": "Products",
			"item": [
				{
					"name": "Get All Products",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.length > 0) {",
									"    // Get the first ID for general work",
									"    pm.collectionVariables.set(\"active_product_id\", jsonData[0].id);",
									"    ",
									"    // Get the last ID for deletions (per user request)",
									"    pm.collectionVariables.set(\"last_product_id\", jsonData[jsonData.length - 1].id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": "http://localhost:8000/api/products/"
					}
				},
				{
					"name": "Get Product by ID",
					"request": {
						"method": "GET",
						"header": [],
						"url": "http://localhost:8000/api/products/{{active_product_id}}/"
					}
				},
				{
					"name": "Create Product",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"New Dynamic Product\",\n    \"price\": 120.50,\n    \"description\": \"Test Product\",\n    \"count\": 15,\n    \"is_active\": true,\n    \"category\": {{active_category_id}}\n}",
							"options": {"raw": {"language": "json"}}
						},
						"url": "http://localhost:8000/api/products/"
					}
				}
			]
		},
		{
			"name": "Cleanup (Deletes)",
			"item": [
				{
					"name": "Delete Product",
					"request": {
						"method": "DELETE",
						"header": [],
						"url": "http://localhost:8000/api/products/{{last_product_id}}/"
					}
				},
				{
					"name": "Delete Category",
					"request": {
						"method": "DELETE",
						"header": [],
						"url": "http://localhost:8000/api/categories/{{last_category_id}}/"
					}
				}
			]
		}
	],
	"variable": [
		{
			"key": "active_category_id",
			"value": "1"
		},
		{
			"key": "last_category_id",
			"value": "1"
		},
		{
			"key": "active_product_id",
			"value": "1"
		},
		{
			"key": "last_product_id",
			"value": "1"
		}
	]
}
